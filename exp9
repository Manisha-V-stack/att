package week9;

import java.util.List;

import org.openqa.selenium.By;
import org.openqa.selenium.WebDriver;
import org.openqa.selenium.chrome.ChromeDriver;

public class exp9 {

    public static void main(String[] args) {

        WebDriver driver = new ChromeDriver();

        driver.manage().window().maximize();

        driver.get("https://www.justdial.com/Hyderabad/Bakeries/nct-10033880?trkId=11687-hyderabad-fcat-catsle&term=Bakeries&ctg=");

        List<WebElement> m = driver.findElements(By.xpath("//h2[@class='jsx-da11ab0664a117 resultbox_title font22 fw500 color111 compist_title']"));

        for(int i = 0; i < m.size(); i++) {

            String s = m.get(i).getText();

            System.out.println("Text is :" + s);
        }
    }
}
